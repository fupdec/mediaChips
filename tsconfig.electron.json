{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".electron-build",
    "rootDir": ".",
    "moduleDetection": "force",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsc/electron.tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "shared/electron/**/*.ts"]
}
