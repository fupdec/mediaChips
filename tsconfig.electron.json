{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".electron-build",
    "rootDir": "electron",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["electron/*.ts"]
}
