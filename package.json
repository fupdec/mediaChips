{
  "name": "mediachips",
  "productName": "MediaChips",
  "version": "0.14.2-beta",
  "author": {
    "name": "MediaChips contributors"
  },
  "homepage": "https://mediachips.app",
  "description": "Organize your media files with ease and convenience.",
  "private": false,
  "license": "GPL-3.0",
  "repository": "github:fupdec/MediaChips",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit && npm run type-check:shared && npm run type-check:node && npm run type-check:electron && npm run type-check:main && npm run type-check:app:strict && npm run type-check:api:strict && npm run type-check:scripts",
    "type-check:shared": "tsc -p tsconfig.shared.json",
    "type-check:node": "tsc -p tsconfig.node.json --noEmit",
    "type-check:electron": "tsc -p tsconfig.electron-strict.json",
    "type-check:main": "tsc -p tsconfig.main-strict.json",
    "type-check:app:strict": "tsc -p tsconfig.app-strict.json",
    "type-check:api:strict": "tsc -p tsconfig.api-strict.json",
    "type-check:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "build:electron": "tsc -p tsconfig.electron.json && cp .electron-build/electron/*.js electron/",
    "build:main": "tsc -p tsconfig.main.json && cp .main-build/main.js main.js",
    "build:app": "tsc -p tsconfig.app.json && rsync -a .app-build/app/ app/",
    "build:api": "tsc -p tsconfig.api.json && rsync -a .api-build/api/ api/",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "build:backend": "node scripts/parallel-npm.mjs build:app build:api",
    "build:electron-artifacts": "node scripts/parallel-npm.mjs build:electron build:main build:backend",
    "build:artifacts": "npm run build:scripts && npm run build:electron-artifacts",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "server": "node app/server.js",
    "server-lan": "node -e \"process.env.MEDIA_CHIPS_ALLOW_LAN='1'; require('./app/server.js')\"",
    "server-dev": "nodemon --watch app --watch api --ext ts --delay 1 --exec \"npm run build:backend && node app/server.js\"",
    "server-dev:fast": "nodemon --watch app --watch api --ext ts --delay 1.5 --exec \"npm run build:app && npm run build:api && node app/server.js\"",
    "electron": "node scripts/electron-dev.mjs",
    "electron:built": "npm run build && npm run build:electron-artifacts && node scripts/ensure-electron-native.mjs && node scripts/electron-built.mjs",
    "electron:gpu-debug": "node scripts/ensure-electron-native.mjs && electron . --in-process-gpu",
    "download-parser-model": "node .scripts-build/download-parser-model.js",
    "prepack": "npm run download-parser-model",
    "pack": "electron-builder --dir",
    "predist": "npm run download-parser-model",
    "preportable": "npm run download-parser-model",
    "portable": "electron-builder --win portable",
    "dist": "electron-builder",
    "dist:publish": "npm run build && npm run predist && electron-builder --publish always",
    "dist:win": "npm run predist && electron-builder --win --publish always",
    "dist:mac": "npm run predist && electron-builder --mac --publish always",
    "dist:linux": "npm run predist && electron-builder --linux --publish always",
    "dist:win:ci": "npm run predist && electron-builder --win --publish never",
    "dist:mac:ci": "npm run predist && electron-builder --mac --publish never",
    "dist:linux:ci": "npm run predist && electron-builder --linux --publish never",
    "rebuild:node": "npm rebuild better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:introspect": "drizzle-kit introspect",
    "rebuild:electron": "node scripts/ensure-electron-native.mjs --force",
    "preserver": "npm run build:backend && npm run rebuild:node",
    "preserver-dev": "npm run build:backend && npm run rebuild:node",
    "predownload-parser-model": "npm run build:scripts",
    "postinstall": "npm run rebuild:node && npm run rebuild:electron && npm run build:artifacts"
  },
  "main": "main.js",
  "overrides": {
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.4.2",
    "chokidar": "^5.0.0",
    "connect-history-api-fallback": "^2.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.6.2",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "filepond": "^4.32.10",
    "filepond-plugin-file-encode": "^2.1.14",
    "filepond-plugin-file-validate-type": "^1.2.9",
    "fs-extra": "^11.3.5",
    "gsap": "^3.14.1",
    "jimp": "^1.6.1",
    "lodash": "^4.17.21",
    "mitt": "^3.0.1",
    "node-machine-id": "^1.1.12",
    "node-stream-zip": "^1.15.0",
    "path-browserify": "^1.0.1",
    "pinia": "^2.3.1",
    "rimraf": "^6.1.3",
    "string-crypto": "^3.0.2",
    "v-viewer": "^3.0.22",
    "viewerjs": "^1.11.7",
    "vue": "^3.5.0",
    "vue-advanced-cropper": "^2.8.9",
    "vue-country-flag-next": "^2.3.2",
    "vue-filepond": "^7.0.4",
    "vue-i18n": "^11.2.2",
    "vue-router": "^4.3.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.11.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "sass-embedded": "^1.95.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-vuetify": "^2.1.2",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "build": {
    "appId": "com.mediachips.app",
    "productName": "MediaChips",
    "copyright": "Copyright © 2026 MediaChips",
    "directories": {
      "output": "release"
    },
    "files": [
      "!databases",
      "!app_storage",
      "!src"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**",
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*",
          "!**/clip-vit-base-patch32/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}.v${version}.Windows.Installer.${ext}",
      "verifyUpdateCodeSignature": false,
      "icon": "public/icons/icon.png"
    },
    "portable": {
      "artifactName": "${productName}.v${version}.Windows.Portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "public/icons/icon.png",
      "artifactName": "${productName}.v${version}.Linux.AppImage",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "dmg": {
      "artifactName": "${productName}.v${version}.Mac.${arch}.${ext}",
      "title": "Install ${productName}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 180
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "mac": {
      "icon": "public/icons/icons.icns",
      "category": "public.app-category.utilities",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "${productName}.v${version}.Mac.${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "fupdec",
      "repo": "MediaChips"
    }
  }
}
