{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".scripts-build",
    "rootDir": "scripts",
    "moduleDetection": "force",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["scripts/**/*.ts"]
}
