{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".app-build",
    "rootDir": ".",
    "moduleDetection": "force",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsc/app.tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["app/**/*.ts"]
}
