{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".app-build",
    "rootDir": ".",
    "moduleDetection": "force",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": false,
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsc/app.tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["app/**/*.ts", "app/types/**/*.d.ts", "shared/**/*.ts", "api/types/**/*.d.ts"]
}
