{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".main-build",
    "moduleDetection": "force",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsc/main.tsbuildinfo",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["main.ts", "types/electron-main.d.ts"]
}
